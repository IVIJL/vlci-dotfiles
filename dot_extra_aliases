alias cc='claude'
alias ccc='claude -c'
alias cccd='claude -c --dangerously-skip-permissions'
alias ccdd='claude --dangerously-skip-permissions'

alias piup='pip install -U pip'

pyclean () {
    find . -type f -name '*.py[co]' -delete -o -type d -name __pycache__ -delete
}

alias gs='git status'
alias gp='git pull'
