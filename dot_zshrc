# Completion system
#
# NOTE: All fpath additions for plugins that ship a _completion file
# MUST go here, BEFORE compinit. Plugins that use `compdef` (e.g. uv,
# uvx) work fine after compinit and can stay in their own sections.

# Add zsh-completions to fpath if available
if [ -d /usr/share/zsh-completions/src ]; then
    # shellcheck disable=SC2206
    fpath=(/usr/local/share/zsh/site-functions /usr/share/zsh-completions/src $fpath)
fi

# zsh-z ships _zshz completion file in its directory
if [ -d /usr/share/zsh-z ]; then
    # shellcheck disable=SC2206
    fpath=(/usr/share/zsh-z $fpath)
fi

autoload -Uz compinit
compinit -d ~/.cache/zcompdump

zstyle ':completion:*:*:*:*:*' menu select
zstyle ':completion:*' completer _complete _approximate
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Z}' # case insensitive tab completion
zstyle ':completion:*' insert-tab pending             # pasting with tabs doesn't perform completion

# Use LS_COLORS for completion if available — zsh parameter expansion syntax
if [ -n "$LS_COLORS" ]; then
    # shellcheck disable=SC2296
    zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
fi

