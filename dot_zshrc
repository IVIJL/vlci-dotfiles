# Custom functions

# Create a new executable script and open it in nano
nanox() {
    if [ -z "$1" ]; then
        echo "usage: $0 <newfilename>"
        return 1
    fi
    if [ ! -e "$1" ]; then
        echo -e "#!/usr/bin/env bash\n\nset -eo pipefail\n" > "$1"
    fi
    chmod -v 0755 "$1"
    nano + "$1"
}

