# Path configuration
# Uses zsh path array (tied to $PATH). typeset -U removes duplicates.
# $^path(N-/) filters out non-existent directories.

export PYENV_ROOT="$HOME/.pyenv"
export NVM_DIR="$HOME/.nvm"

path=(
    "$HOME/bin"
    "$HOME/.local/bin"
    "$PYENV_ROOT/bin"
    "$PYENV_ROOT/shims"
    "$HOME/.cargo/bin"
    $path
)

# Remove duplicate entries and non-existent directories
typeset -U path
path=($^path(N-/))

export PATH

