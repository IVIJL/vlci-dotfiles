elif command -v exa &>/dev/null; then
    alias ll='exa --icons --group-directories-first --octal-permissions --time-style=long-iso -lsnew -lha'
    alias lt='exa --tree --icons --level=2 --long --time-style=long-iso -ah -I ".git|__pycache__|.mypy_cache|.ipynb_checkpoints"'
else
    alias ll='ls -alhF'
fi
alias la='ls -A'
alias l='ls -CF'

# history
alias history="history 0"

# quick awk field extraction — \$N is awk's positional param, not shell's
alias hg='history | grep '
alias f1="awk '{print \$1}'"
alias f2="awk '{print \$2}'"
alias f3="awk '{print \$3}'"

# Extra aliases from optional file (docker, project-specific, etc.)
