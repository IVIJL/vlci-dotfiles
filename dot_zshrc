# Tool initialization (lazy-loaded where possible for fast shell startup)

# ── pyenv (lazy) ─────────────────────────────────────────────
if [ -x "$PYENV_ROOT/bin/pyenv" ]; then
    pyenv() {
        unfunction pyenv
        eval "$("$PYENV_ROOT/bin/pyenv" init - zsh)"
        pyenv "$@"
    }
fi

# ── nvm (lazy) ───────────────────────────────────────────────
if [ -s "$NVM_DIR/nvm.sh" ]; then
    nvm() {
        unfunction nvm node npm npx 2>/dev/null
        # shellcheck disable=SC1091
        [ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
        nvm "$@"
    }
    # Lazy stubs for node/npm/npx — triggers nvm load on first use
    node() { nvm ""; unfunction node 2>/dev/null; node "$@"; }
    npm()  { nvm ""; unfunction npm  2>/dev/null; npm "$@";  }
    npx()  { nvm ""; unfunction npx  2>/dev/null; npx "$@";  }
fi
[ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# ── cargo ────────────────────────────────────────────────────
[ -s "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# ── uv / uvx completions ────────────────────────────────────
command -v uvx >/dev/null 2>&1 && eval "$(uvx --generate-shell-completion zsh)"
command -v uv  >/dev/null 2>&1 && eval "$(uv  generate-shell-completion zsh)"

# ── GRC colorizer ────────────────────────────────────────────
[[ -s "/etc/grc.zsh" ]] && source /etc/grc.zsh

# ── command-not-found ────────────────────────────────────────
[ -f /etc/zsh_command_not_found ] && source /etc/zsh_command_not_found

# ── SSH agent via keychain ───────────────────────────────────
command -v keychain >/dev/null 2>&1 && eval "$(keychain --eval --quiet --agents ssh)"

# ── WezTerm (tab title / CWD tracking) ────────────────────
if [ -n "$DEVCONTAINER" ]; then
    # Export project name for WezTerm tab title (no OSC 7 — container paths don't exist on host)
    printf '\033]1337;SetUserVar=devbox_project=%s\007' "$(printf '%s' "${HOSTNAME}" | base64)"
else
    # Host: OSC 7 for CWD tracking (tab duplication with correct directory)
    # shellcheck disable=SC1003
    __wezterm_osc7() {
        printf '\033]7;file://%s%s\033\\' "${HOSTNAME}" "${PWD}"
    }
    precmd_functions+=(__wezterm_osc7)
fi

